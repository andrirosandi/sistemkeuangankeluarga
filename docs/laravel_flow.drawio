<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-05" agent="Claude Code" version="24.0.0">
  <diagram id="laravel-flow-simple" name="Laravel Request Flow">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="&lt;h2&gt;Laravel Request Flow — Sistem Keuangan Keluarga&lt;/h2&gt;" style="rounded=0;whiteSpace=wrap;html=1;shadow=0;fillColor=none;strokeColor=none;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="650" height="35" as="geometry" />
        </mxCell>

        <!-- Step 1: User -->
        <mxCell id="user" value="👤 User&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;(Browser)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Arrow 1 -->
        <mxCell id="a1" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#555555;strokeWidth=2;" edge="1" source="user" target="routes" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="250" y="127"/></mxGeometry>
        </mxCell>

        <!-- Step 2: Routes -->
        <mxCell id="routes" value="routes/&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;web.php / auth.php&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#2E7D32;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="100" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Arrow 2 -->
        <mxCell id="a2" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#555555;strokeWidth=2;" edge="1" source="routes" target="middleware" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="450" y="127"/></mxGeometry>
        </mxCell>

        <!-- Step 3: Middleware -->
        <mxCell id="middleware" value="Middleware&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;auth, can, verified&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="100" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Arrow 3 -->
        <mxCell id="a3" style="rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#555555;strokeWidth=2;" edge="1" source="middleware" target="controller" parent="1">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="650" y="127"/></mxGeometry>
        </mxCell>

        <!-- Step 4: Controller -->
        <mxCell id="controller" value="Controller&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;validate request&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#6A1B9A;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="100" width="120" height="55" as="geometry" />
        </mxCell>

        <!-- Arrow 4 -->
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#555555;strokeWidth=2;" edge="1" source="controller" target="service" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="710" y="250"/>
              <mxPoint x="710" y="250"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 5: Service -->
        <mxCell id="service" value="Service&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;business logic&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#283593;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="250" width="170" height="55" as="geometry" />
        </mxCell>

        <!-- Arrow 5 -->
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#555555;strokeWidth=2;" edge="1" source="service" target="model" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="685" y="400"/>
              <mxPoint x="490" y="400"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 6: Model -->
        <mxCell id="model" value="Model&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;Eloquent ORM&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="390" y="380" width="160" height="55" as="geometry" />
        </mxCell>

        <!-- Arrow 6 -->
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#555555;strokeWidth=2;" edge="1" source="model" target="database" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="470" y="490"/>
              <mxPoint x="270" y="490"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Step 7: Database -->
        <mxCell id="database" value="Database&#xa;&lt;font style=&quot;font-size:10px&quot;&gt;MySQL&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#263238;strokeColor=#37474F;fontColor=#ffffff;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="160" y="380" width="160" height="55" as="geometry" />
        </mxCell>

        <!-- Return arrow -->
        <mxCell id="ar" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#43A047;strokeWidth=2;" edge="1" source="user" target="database" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="110" y="407" as="targetPoint"/>
          </mxGeometry>
        </mxCell>

        <mxCell id="label_return" value="Response" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;fontStyle=2;fontColor=#43A047;" vertex="1" parent="1">
          <mxGeometry x="140" y="280" width="60" height="30" as="geometry" />
        </mxCell>

        <!-- Detail box -->
        <mxCell id="detail" value="&lt;b&gt;Contoh Rute&lt;/b&gt;&#xa;&#xa;GET /kas-masuk/pengajuan → RequestController@index&#xa;POST /kas-masuk/pengajuan/{id}/approve → RequestController@approve&#xa;POST /kas-masuk/realisasi → TransactionController@store&#xa;GET /laporan → ReportController@index&#xa;GET /api/dashboard/balance → DashboardController@widgetBalance&#xa;&#xa;&lt;b&gt;Contoh Service → Model&lt;/b&gt;&#xa;&#xa;FinanceRequestService → RequestHeader / RequestDetail&#xa;TransactionService → TransactionHeader / TransactionDetail → BalanceService&#xa;NotificationService → Notification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FAFAFA;strokeColor=#9E9E9E;fontSize=9;align=left;" vertex="1" parent="1">
          <mxGeometry x="50" y="470" width="500" height="120" as="geometry" />
        </mxCell>

